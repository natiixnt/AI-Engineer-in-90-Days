flowchart LR
  UI["User Input"] --> PC["Prompt Construction"]
  PC --> CTX["Context / Retrieved Data"]
  CTX --> LI["LLM Inference"]
  LI --> OP["Output Parsing"]
  OP --> FR["Final Response"]

  SP["System Prompt"] -.inject.-> PC
  UP["User Prompt"] -.inject.-> PC
  LI -.invoke / results.-> TC["Tool Calls"]
  GR["Guardrails"] -.validate.-> OP
  LI -.telemetry.-> LOG["Logging / Monitoring"]
  OP -.telemetry.-> LOG

  classDef input fill:#EEF2FF,stroke:#4338CA,stroke-width:1.2px,color:#1E1B4B;
  classDef core fill:#F8FAFC,stroke:#1E293B,stroke-width:1.2px,color:#0F172A;
  classDef data fill:#ECFEFF,stroke:#0E7490,stroke-width:1.2px,color:#164E63;
  classDef model fill:#FFF7ED,stroke:#C2410C,stroke-width:1.2px,color:#7C2D12;
  classDef output fill:#E2FBE8,stroke:#15803D,stroke-width:1.2px,color:#166534;

  class UI,SP,UP input;
  class PC,OP core;
  class CTX,TC,GR,LOG data;
  class LI model;
  class FR output;
